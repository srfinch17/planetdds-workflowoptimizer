# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit the real key.

# Your Anthropic API key from console.anthropic.com (starts with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Which Claude model to use. Haiku = cheapest, plenty smart for intent extraction.
ANTHROPIC_MODEL=claude-haiku-4-5

# Force offline mode (skip all LLM calls, use deterministic rule-based path only).
# Set to "true" to demo graceful degradation / guarantee zero API cost.
SCHEDULER_OFFLINE=false
